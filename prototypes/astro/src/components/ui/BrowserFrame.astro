---
interface Props {
  aspect?: string;
  label?: string;
}
const { aspect = '16/10', label = 'Screenshot del progetto' } = Astro.props;
---
<div class="browser-frame">
  <div class="browser-frame__bar">
    <span class="browser-frame__dot"></span>
    <span class="browser-frame__dot"></span>
    <span class="browser-frame__dot"></span>
    <span class="mono browser-frame__url">studioremarka.it</span>
  </div>
  <div class="browser-frame__image" style={`aspect-ratio:${aspect}`}>
    <span class="visually-hidden">{label}</span>
  </div>
</div>

<style>
  .browser-frame__url {
    font-size: 12px;
    color: var(--grigio);
    margin-left: 6px;
  }
  .browser-frame__image {
    background:
      linear-gradient(135deg, var(--traccia) 25%, transparent 25%) -10px 0/20px 20px,
      linear-gradient(225deg, var(--traccia) 25%, transparent 25%) -10px 0/20px 20px,
      linear-gradient(315deg, var(--traccia) 25%, transparent 25%) 0px 0/20px 20px,
      linear-gradient(45deg, var(--traccia) 25%, transparent 25%) 0px 0/20px 20px;
    background-color: var(--carta);
  }
</style>
