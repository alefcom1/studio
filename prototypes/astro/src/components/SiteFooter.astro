---
import Logo from './Logo.astro';
import CookieBanner from './CookieBanner.astro';
import WhatsAppFab from './WhatsAppFab.astro';

const pagine = [
  { href: '/servizi', label: 'Servizi' },
  { href: '/casi-studio', label: 'Casi studio' },
  { href: '/prezzi', label: 'Prezzi' },
  { href: '/strumenti', label: 'Strumenti' },
  { href: '/blog', label: 'Blog' },
];
const studio = [
  { href: '/chi-siamo', label: 'Chi siamo' },
  { href: '/citta/milano', label: 'Milano' },
  { href: '/#contatti', label: 'Contatti' },
  { href: '/privacy', label: 'Privacy policy' },
  { href: '/cookie-policy', label: 'Cookie policy' },
];
---
<footer class="site-footer">
  <div class="container site-footer__grid">
    <div>
      <a href="/" class="site-header__brand footer-brand">
        <Logo size={26} />
        <span>Studio Remarka</span>
      </a>
      <p class="body-text footer-blurb">
        Siti progressivi per PMI italiane. Parte del gruppo Remarka, agenzia di traduzioni dal 2001.
      </p>
    </div>

    <div>
      <p class="footer-heading">Pagine</p>
      <ul class="footer-links">
        {pagine.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>

    <div>
      <p class="footer-heading">Studio</p>
      <ul class="footer-links">
        {studio.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>

    <div>
      <p class="footer-heading">Dati societari</p>
      <p class="mono footer-legal">
        Studio Remarka S.r.l.<br />
        Via Andrea Solari 43, 20144 Milano (MI)<br />
        P.IVA 12345678901<br />
        PEC studioremarka@pec.it
      </p>
    </div>
  </div>

  <div class="site-footer__signature">
    <div class="barra" style="height:3px" data-barra data-barra-delay="0">
      <div class="barra__fill" style="--barra-target:97%"></div>
    </div>
    <div class="container site-footer__bottom">
      <p class="mono">© {new Date().getFullYear()} Studio Remarka S.r.l. — Tutti i diritti riservati.</p>
      <p class="mono footer-score">PAGESPEED DI QUESTA PAGINA: <span style="color:var(--verde)">98/100</span></p>
    </div>
  </div>

  <CookieBanner />
  <WhatsAppFab />
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--bordo);
    background: var(--carta);
    padding-top: 72px;
  }
  .site-footer__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 48px 40px;
    padding-bottom: 56px;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 11px;
    color: var(--inchiostro);
  }
  .footer-brand span {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
  }
  .footer-blurb {
    margin-top: 16px;
    max-width: 280px;
  }
  .footer-heading {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--grigio);
    margin: 0 0 16px;
  }
  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .footer-links a {
    color: var(--inchiostro);
    font-size: 15px;
  }
  .footer-links a:hover {
    color: var(--oltremare);
  }
  .footer-legal {
    font-size: 13px;
    line-height: 1.7;
    color: var(--grigio);
    margin: 0;
  }
  .site-footer__signature {
    margin-top: 8px;
  }
  .site-footer__bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 8px;
    padding: 20px 24px;
    font-size: 12px;
    color: var(--grigio);
  }
  .site-footer__bottom p {
    margin: 0;
  }
</style>
