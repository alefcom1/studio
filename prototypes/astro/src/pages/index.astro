---
import BaseLayout from '../layouts/BaseLayout.astro';
import GridBackground from '../components/ui/GridBackground.astro';
import Barra from '../components/ui/Barra.astro';
import StatBlock from '../components/ui/StatBlock.astro';
import BrowserFrame from '../components/ui/BrowserFrame.astro';
import SpeedWidget from '../components/SpeedWidget.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import ContactForm from '../components/ContactForm.astro';

const trustWordmarks = ['OFFICINE RIVA', 'Cantina Serralta', 'TECNOIDRAULICA', 'Studio Fontana', 'B&B Il Cortile'];

const treNumeri = [
  { value: '97', color: 'var(--verde)', caption: 'PageSpeed medio dei nostri siti', description: 'Misurato su mobile con Lighthouse, media degli ultimi 12 progetti consegnati.' },
  { value: '−38%', color: 'var(--oltremare)', caption: 'Tempo di caricamento dopo il restyling', description: 'Confronto prima/dopo sugli otto restyling completati nel 2025.' },
  { value: '4', color: 'var(--oltremare)', caption: 'Lingue native in ogni progetto', description: 'Italiano, inglese, tedesco e francese, tradotti da madrelingua — non da un plugin.' },
];

const servizi = [
  { title: 'Siti aziendali', desc: 'Struttura chiara e caricamento sotto il secondo per chi vive di richieste di preventivo.' },
  { title: 'E-commerce', desc: 'Cataloghi veloci e checkout senza attriti, con fatturazione elettronica integrata.' },
  { title: 'Siti progressivi PWA', desc: 'Un sito che si comporta come un’app: installabile, funziona anche offline, apre all’istante.' },
  { title: 'Restyling e migrazione', desc: 'Il vostro sito attuale, ricostruito: stessi contenuti, il triplo della velocità.' },
  { title: 'SEO tecnica', desc: 'Struttura, dati e Core Web Vitals a posto prima ancora di scrivere i contenuti.' },
  { title: 'Siti multilingue', desc: 'Quattro lingue tradotte da madrelingua: dal 2001 è il mestiere del gruppo Remarka.' },
];

const passaggi = [
  { n: '01', durata: '2 GIORNI', titolo: 'Analisi', desc: 'Report tecnico del sito attuale, con priorità e obiettivi misurabili.' },
  { n: '02', durata: '24 ORE', titolo: 'Preventivo fisso', desc: 'Prezzo chiuso e data di consegna, scritti nel contratto.' },
  { n: '03', durata: '1–2 SETTIMANE', titolo: 'Design', desc: 'Prototipo navigabile da approvare pagina per pagina, non PDF statici.' },
  { n: '04', durata: '2–4 SETTIMANE', titolo: 'Sviluppo', desc: 'Sito su ambiente di prova, avanzamento visibile ogni venerdì.' },
  { n: '05', durata: '12 MESI', titolo: 'Consegna e assistenza', desc: 'Formazione all’uso, misurazioni mensili e assistenza inclusa.' },
];

const garanzie = [
  { value: '90+', titolo: 'PageSpeed garantito', desc: 'Se il punteggio mobile scende sotto 90, interveniamo entro cinque giorni lavorativi. Gratuitamente.' },
  { value: '±0 gg', titolo: 'Consegna a data fissa', desc: 'La data è nel contratto. Ogni giorno lavorativo di ritardo: 1% di sconto sul totale.' },
  { value: '12 mesi', titolo: 'Assistenza inclusa', desc: 'Aggiornamenti, backup e piccole modifiche compresi nel prezzo, con report mensile.' },
];

const tariffe = [
  { nome: 'Sito vetrina', per: 'Presenza professionale: cinque pagine, una lingua, modulo contatti.', tempi: '3 sett.', prezzo: '€ 1.900–2.800' },
  { nome: 'Sito aziendale', per: 'Quindici pagine, due lingue, CMS e SEO tecnica completa.', tempi: '5–7 sett.', prezzo: '€ 3.900–5.800' },
  { nome: 'E-commerce', per: 'Catalogo, pagamenti, fatturazione elettronica integrata.', tempi: '8–10 sett.', prezzo: '€ 7.500–14.000' },
];

const strumenti = [
  { idx: '/01', titolo: 'Test velocità', desc: 'Il PageSpeed reale del vostro sito, spiegato in italiano.', href: '/strumenti/test-velocita' },
  { idx: '/02', titolo: 'Check GDPR e cookie', desc: 'Banner, informative e consensi: cosa manca per essere a norma.', href: '/strumenti/check-gdpr' },
  { idx: '/03', titolo: 'Analisi SEO on-page', desc: 'Titoli, struttura e dati mancanti sulla pagina che conta di più.', href: '/strumenti/analisi-seo' },
  { idx: '/04', titolo: 'ROI localizzazione', desc: 'Quanto rende tradurre il sito in inglese o tedesco.', href: '/strumenti/roi-localizzazione' },
];
---
<BaseLayout
  title="Siti veloci che vendono"
  description="Studio Remarka progetta siti progressivi per PMI italiane: PageSpeed 90+ garantito da contratto, consegna a data fissa, prezzo chiuso."
  active="none"
>
  <!-- 1. Hero -->
  <section class="section section--hero rule hero">
    <GridBackground />
    <div class="container hero__inner">
      <div class="hero__copy" data-reveal-cascade>
        <p class="eyebrow">Studio di sviluppo web</p>
        <h1 class="h1">Siti veloci che vendono<span class="accent-dot">.</span></h1>
        <p class="lede">Progettiamo siti progressivi per PMI italiane: PageSpeed 90+ garantito da contratto, consegna a data fissa, prezzo chiuso.</p>
        <div class="hero__actions">
          <a href="/strumenti/test-velocita" class="btn btn-primary">Analizza il tuo sito — gratis</a>
          <a href="#contatti" class="btn btn-outline">Preventivo in 24 ore</a>
        </div>
      </div>
      <div class="hero__widget" data-reveal data-reveal-delay="320">
        <SpeedWidget score={97} />
      </div>
    </div>
  </section>

  <!-- 2. Trust strip -->
  <section class="bg-bianco rule">
    <div class="container trust-strip">
      <p class="trust-strip__line">
        Dal 2001 nel settore linguistico e digitale · P.IVA verificabile · Recensioni Google
        <span class="accent-dot">★</span> <span class="mono">4,9</span>
      </p>
      <div class="trust-strip__marks">
        {trustWordmarks.map((m) => <span>{m}</span>)}
      </div>
    </div>
  </section>

  <!-- 3. Tre numeri -->
  <section class="section">
    <div class="container tre-numeri">
      {treNumeri.map((n, i) => (
        <div data-reveal data-reveal-delay={i * 80}>
          <StatBlock value={n.value} color={n.color} caption={n.caption} description={n.description} />
        </div>
      ))}
    </div>
  </section>

  <!-- 4. Servizi -->
  <section class="section rule" style="border-top:1px solid var(--bordo)">
    <div class="container">
      <div data-reveal style="max-width:640px">
        <p class="eyebrow">Servizi</p>
        <h2 class="h2">Sei cose che sappiamo fare bene<span class="accent-dot">.</span></h2>
      </div>
      <div class="servizi-grid" data-reveal-cascade>
        {servizi.map((s) => (
          <a href="/servizi" class="card servizi-card">
            <h3 class="card-title">{s.title}</h3>
            <p class="body-text" style="margin-top:10px">{s.desc}</p>
            <span class="servizi-card__link">Scopri →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Caso studio in evidenza -->
  <section class="section bg-bianco" style="border-top:1px solid var(--bordo)">
    <div class="container">
      <div data-reveal class="caso-header">
        <div>
          <p class="eyebrow">Caso studio</p>
          <h2 class="h2">Arredamenti Colombo, Lissone<span class="accent-dot">.</span></h2>
        </div>
        <a href="/casi-studio" class="caso-header__link">Tutti i casi studio →</a>
      </div>
      <div class="caso-body" data-reveal-cascade>
        <div class="caso-body__frame">
          <BrowserFrame aspect="16/10" label="Screenshot del sito Arredamenti Colombo" />
        </div>
        <div class="caso-body__stats">
          <div class="caso-bar">
            <div class="caso-bar__row"><span class="eyebrow" style="margin:0">Prima</span><span class="mono" style="font-size:26px;color:var(--grigio)">34</span></div>
            <Barra target={34} muted height={8} />
          </div>
          <div class="caso-bar">
            <div class="caso-bar__row"><span class="eyebrow" style="margin:0">Dopo</span><span class="mono" style="font-size:26px;color:var(--verde)">96</span></div>
            <Barra target={96} delay={150} height={8} />
          </div>
          <div class="caso-metrics">
            <div class="caso-metrics__row"><span class="mono caso-metrics__val">−2,9 s</span><span class="body-text">di caricamento: da 4,1 a 1,2 secondi</span></div>
            <div class="caso-metrics__row"><span class="mono caso-metrics__val">+41%</span><span class="body-text">richieste di preventivo in sei mesi</span></div>
            <div class="caso-metrics__row"><span class="mono caso-metrics__val">Pag. 1</span><span class="body-text">su Google per «arredamenti su misura Lissone»</span></div>
          </div>
          <a href="/casi-studio/arredamenti-colombo" class="caso-header__link" style="margin-top:24px;display:inline-block">Leggi il caso completo →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Come lavoriamo -->
  <section class="section">
    <div class="container">
      <div data-reveal style="max-width:640px">
        <p class="eyebrow">Come lavoriamo</p>
        <h2 class="h2">Cinque passaggi, una data<span class="accent-dot">.</span></h2>
      </div>
      <div class="passaggi" data-reveal-cascade>
        {passaggi.map((p) => (
          <div class="passaggi__item">
            <div class="passaggi__top">
              <span class="mono" style="color:var(--oltremare);font-size:14px">{p.n}</span>
              <span class="mono" style="color:var(--grigio);font-size:12px;letter-spacing:0.08em">{p.durata}</span>
            </div>
            <h3 class="card-title" style="font-size:21px;margin-top:14px">{p.titolo}</h3>
            <p class="body-text" style="font-size:14.5px;margin-top:8px">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. Garanzie (dark) -->
  <section class="section bg-dark">
    <div class="container">
      <div data-reveal style="max-width:640px">
        <p class="eyebrow">Garanzie</p>
        <h2 class="h2">Nero su bianco<span class="accent-dot">.</span></h2>
        <p class="body-text" style="margin-top:18px;font-size:17px;color:rgba(247,246,242,0.66)">Tre clausole del nostro contratto standard. Non promesse commerciali: obblighi firmati.</p>
      </div>
      <div class="garanzie-grid" data-reveal-cascade>
        {garanzie.map((g) => (
          <div class="stat-block">
            <span class="stat-block__number mono" style="color:var(--oltremare-chiaro)">{g.value}</span>
            <p style="margin:16px 0 0;font-size:17px;font-weight:500;color:var(--carta)">{g.titolo}</p>
            <p style="margin:8px 0 0;font-size:15px;line-height:1.6;color:rgba(247,246,242,0.66)">{g.desc}</p>
          </div>
        ))}
      </div>
      <p class="mono" style="margin:56px 0 0;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(247,246,242,0.4)">
        Estratto dagli artt. 4–6 del contratto standard — copia su richiesta
      </p>
    </div>
  </section>

  <!-- 8. Prezzi teaser -->
  <section class="section">
    <div class="container">
      <div data-reveal class="caso-header">
        <div>
          <p class="eyebrow">Prezzi</p>
          <h2 class="h2">Prezzi trasparenti. Nessuna sorpresa in corso d’opera<span class="accent-dot">.</span></h2>
        </div>
        <a href="/prezzi" class="caso-header__link">Confronta le tariffe →</a>
      </div>
      <div class="prezzi-table-wrap" data-reveal>
        <table class="prezzi-table">
          <thead>
            <tr>
              <th>Tariffa</th>
              <th>Per chi</th>
              <th>Tempi</th>
              <th style="text-align:right">Prezzo</th>
            </tr>
          </thead>
          <tbody>
            {tariffe.map((t) => (
              <tr>
                <td class="prezzi-table__nome">{t.nome}</td>
                <td class="body-text" style="font-size:15px">{t.per}</td>
                <td class="mono" style="font-size:14px;color:var(--grigio)">{t.tempi}</td>
                <td class="mono prezzi-table__prezzo">{t.prezzo}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="prezzi-footer">
        <p class="body-text" style="margin:0;font-size:15px">Il preventivo è un prezzo chiuso: quello che firmate è quello che pagate.</p>
        <a href="#contatti" class="btn btn-primary btn--sm">Richiedi preventivo dettagliato</a>
      </div>
    </div>
  </section>

  <!-- 9. Strumenti gratuiti -->
  <section class="section bg-bianco" style="border-top:1px solid var(--bordo)">
    <div class="container">
      <div data-reveal class="caso-header">
        <div>
          <p class="eyebrow">Strumenti gratuiti</p>
          <h2 class="h2">Prima misurate, poi decidete<span class="accent-dot">.</span></h2>
        </div>
        <p class="body-text" style="margin:0;font-size:15px">Strumenti professionali, gratuiti, senza registrazione.</p>
      </div>
      <div class="strumenti-grid" data-reveal-cascade>
        {strumenti.map((s) => (
          <a href={s.href} class="card strumenti-card">
            <span class="mono" style="color:var(--oltremare);font-size:12px">{s.idx}</span>
            <h3 class="card-title" style="font-size:21px;margin-top:14px">{s.titolo}</h3>
            <p class="body-text" style="font-size:14.5px;margin-top:8px">{s.desc}</p>
            <span class="servizi-card__link" style="font-size:14.5px;margin-top:16px">Prova →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 10. FAQ -->
  <section class="section" style="border-top:1px solid var(--bordo)">
    <div class="container faq-section">
      <div data-reveal class="faq-section__intro">
        <p class="eyebrow">FAQ</p>
        <h2 class="h2">Domande frequenti<span class="accent-dot">.</span></h2>
        <p class="body-text" style="margin-top:18px;font-size:16px;max-width:340px">Risposte concrete, senza rimandi al commerciale. Per tutto il resto: un messaggio, un giorno lavorativo.</p>
      </div>
      <div class="faq-section__list" data-reveal data-reveal-delay="80">
        <FaqAccordion />
      </div>
    </div>
  </section>

  <!-- 11. Contatti -->
  <section id="contatti" class="section bg-bianco" style="border-top:1px solid var(--bordo)">
    <div class="container contatti">
      <div data-reveal class="contatti__intro">
        <p class="eyebrow">Contatti</p>
        <h2 class="h2">Parliamo del tuo progetto<span class="accent-dot">.</span></h2>
        <p class="body-text" style="margin-top:18px;font-size:17px;max-width:400px">Un’analisi gratuita del sito attuale o un preventivo chiuso in 24 ore. Scegliete il canale che preferite.</p>
        <a href="https://wa.me/393458219047" class="contatti__wa" target="_blank" rel="noopener noreferrer">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="#FFFFFF" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2m0 1.67c2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.83c0 4.54-3.7 8.23-8.24 8.23-1.48 0-2.93-.39-4.19-1.15l-.3-.17-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.25 8.25-8.25m-3.53 4.02c-.16 0-.43.06-.66.31-.22.25-.87.85-.87 2.07 0 1.22.89 2.39 1 2.56.13.17 1.76 2.67 4.25 3.73.59.27 1.05.42 1.41.53.59.19 1.13.16 1.56.1.48-.07 1.46-.6 1.67-1.18.2-.58.2-1.07.14-1.18-.06-.11-.22-.16-.47-.28-.25-.13-1.47-.74-1.7-.82-.23-.08-.39-.12-.56.12-.16.25-.64.81-.78.97-.15.17-.29.19-.53.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.55-1.34-.76-1.84-.2-.48-.4-.42-.56-.42-.14-.01-.3-.01-.48-.01"/></svg>
          <span>WhatsApp Business — +39 345 821 9047</span>
        </a>
        <p class="mono" style="margin:16px 0 0;font-size:12px;letter-spacing:0.08em;color:var(--grigio)">LUN–VEN 9:00–18:00 · RISPOSTA ENTRO UN GIORNO LAVORATIVO</p>
      </div>
      <div class="contatti__form" data-reveal data-reveal-delay="120">
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { overflow: hidden; }
  .hero__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 56px;
    align-items: center;
    position: relative;
  }
  .hero__copy { flex: 1 1 480px; min-width: 0; }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 36px; }
  .hero__widget { flex: 1 1 380px; min-width: 0; max-width: 520px; }

  .trust-strip {
    padding: 20px 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px 48px;
    align-items: center;
    justify-content: space-between;
  }
  .trust-strip__line { margin: 0; font-size: 14px; color: var(--grigio); }
  .trust-strip__marks {
    display: flex;
    flex-wrap: wrap;
    gap: 14px 40px;
    align-items: center;
    opacity: 0.75;
    color: var(--client-wordmarks);
    font-size: 15px;
    font-weight: 600;
  }

  .tre-numeri {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 40px 32px;
  }

  .servizi-grid, .strumenti-grid {
    display: grid;
    gap: 20px;
    margin-top: 56px;
  }
  .servizi-grid { grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); }
  .strumenti-grid { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .servizi-card { display: block; }
  .strumenti-card { display: block; background: var(--carta); }
  .servizi-card__link {
    display: inline-block;
    margin-top: 18px;
    font-size: 15px;
    font-weight: 500;
    color: var(--oltremare);
  }

  .caso-header {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 32px;
    align-items: baseline;
    justify-content: space-between;
  }
  .caso-header__link { font-size: 15px; font-weight: 500; color: var(--oltremare); }
  .caso-body {
    display: flex;
    flex-wrap: wrap;
    gap: 48px;
    margin-top: 56px;
    align-items: center;
  }
  .caso-body__frame { flex: 1 1 520px; min-width: 0; }
  .caso-body__stats { flex: 1 1 380px; min-width: 0; }
  .caso-bar { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
  .caso-bar__row { display: flex; justify-content: space-between; align-items: baseline; }
  .caso-metrics { margin-top: 32px; border-top: 1px solid var(--bordo); }
  .caso-metrics__row {
    display: flex;
    gap: 16px;
    align-items: baseline;
    padding: 16px 0;
    border-bottom: 1px solid var(--bordo);
  }
  .caso-metrics__val { font-size: 20px; color: var(--oltremare); min-width: 88px; }

  .passaggi {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 32px 24px;
    margin-top: 56px;
    border-top: 1px solid var(--inchiostro);
  }
  .passaggi__item { padding-top: 24px; }
  .passaggi__top { display: flex; justify-content: space-between; align-items: baseline; }

  .garanzie-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 40px 32px;
    margin-top: 64px;
  }
  .bg-dark .stat-block { border-top-color: var(--dark-rule); }

  .prezzi-table-wrap { margin-top: 56px; overflow-x: auto; }
  .prezzi-table {
    min-width: 760px;
    width: 100%;
    background: var(--bianco);
    border: 1px solid var(--bordo);
    border-collapse: collapse;
  }
  .prezzi-table thead th {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--grigio);
    text-align: left;
    font-weight: 400;
    padding: 14px 28px;
    border-bottom: 1px solid var(--bordo);
  }
  .prezzi-table tbody td {
    padding: 26px 28px;
    border-bottom: 1px solid var(--bordo);
    vertical-align: baseline;
  }
  .prezzi-table tbody tr:last-child td { border-bottom: none; }
  .prezzi-table__nome { font-family: var(--font-display); font-weight: 500; font-size: 21px; color: var(--inchiostro); }
  .prezzi-table__prezzo { font-size: 17px; color: var(--inchiostro); text-align: right; }
  .prezzi-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 32px;
    align-items: center;
    justify-content: space-between;
    margin-top: 28px;
  }

  .faq-section { display: flex; flex-wrap: wrap; gap: 48px 64px; }
  .faq-section__intro { flex: 1 1 280px; }
  .faq-section__list { flex: 1.6 1 480px; }

  .contatti { display: flex; flex-wrap: wrap; gap: 48px 64px; align-items: flex-start; }
  .contatti__intro { flex: 1 1 320px; }
  .contatti__form { flex: 1 1 380px; max-width: 560px; }
  .contatti__wa {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 32px;
    background: var(--whatsapp);
    color: #FFFFFF;
    font-weight: 500;
    font-size: 16px;
    padding: 16px 26px;
    border-radius: var(--radius);
  }
  .contatti__wa:hover { background: var(--whatsapp-hover); color: #FFFFFF; }
</style>
