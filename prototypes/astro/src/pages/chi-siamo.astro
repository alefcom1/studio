---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Chi siamo" description="Studio Remarka: web studio del gruppo Remarka, agenzia di traduzioni dal 2001." active="none">
  <section class="section section--hero rule">
    <div class="container-narrow">
      <p class="eyebrow">Chi siamo</p>
      <h1 class="h1" style="font-size:clamp(34px,4vw,52px)">Un gruppo che lavora con le lingue e con il web dal 2001<span class="accent-dot">.</span></h1>
      <p class="lede" style="max-width:100%">
        Studio Remarka nasce all’interno del gruppo Remarka, agenzia di traduzioni attiva dal 2001. Applichiamo la stessa precisione contrattuale
        alla velocità dei siti che progettiamo: numeri misurati, non promesse commerciali.
      </p>
    </div>
  </section>
</BaseLayout>
