---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GridBackground from '../../components/ui/GridBackground.astro';
import { tools } from '../../data/tools';
---
<BaseLayout title="Strumenti gratuiti" description="Strumenti professionali gratuiti, senza registrazione: velocità, GDPR, SEO, ROI localizzazione." active="strumenti">
  <section class="section section--hero rule hero">
    <GridBackground />
    <div class="container" style="position:relative">
      <p class="eyebrow">Strumenti gratuiti</p>
      <h1 class="h1" style="font-size:clamp(38px,4.6vw,64px)">Prima misurate, poi decidete<span class="accent-dot">.</span></h1>
      <p class="lede">Strumenti professionali, gratuiti, senza registrazione.</p>
    </div>
  </section>

  <section class="section">
    <div class="container strumenti-grid" data-reveal-cascade>
      {tools.map((t) => (
        <a href={`/strumenti/${t.slug}`} class="card strumenti-card">
          <span class="mono" style="color:var(--oltremare);font-size:12px">{t.idx}</span>
          <h2 class="card-title" style="font-size:21px;margin-top:14px">{t.titolo}</h2>
          <p class="body-text" style="font-size:14.5px;margin-top:8px">{t.descrizione}</p>
          <span class="strumenti-card__link">Prova →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .strumenti-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }
  .strumenti-card { display: block; }
  .strumenti-card__link {
    display: inline-block;
    margin-top: 16px;
    font-size: 14.5px;
    font-weight: 500;
    color: var(--oltremare);
  }
</style>
