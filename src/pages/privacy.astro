---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy policy" description="Informativa privacy di Studio Remarka." active="none">
  <section class="section section--hero rule">
    <div class="container-narrow">
      <p class="eyebrow">Privacy policy</p>
      <h1 class="h1" style="font-size:clamp(30px,3.6vw,44px)">Informativa privacy<span class="accent-dot">.</span></h1>
      <p class="body-text" style="margin-top:20px;font-size:16px">
        Contenuto legale da redigere con un consulente privacy prima del lancio. I dati raccolti tramite il modulo contatti restano nell’Unione Europea,
        come indicato nel sito, e non vengono ceduti a terzi per finalità di profilazione.
      </p>
    </div>
  </section>
</BaseLayout>
