---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Preferenze cookie" description="Gestisci le preferenze sui cookie di Studio Remarka." active="none">
  <section class="section section--hero rule">
    <div class="container-narrow">
      <p class="eyebrow">Preferenze cookie</p>
      <h1 class="h1" style="font-size:clamp(30px,3.6vw,44px)">Preferenze cookie<span class="accent-dot">.</span></h1>
      <p class="body-text" style="margin-top:20px;font-size:16px">
        Il sito usa solo cookie tecnici necessari: non esistono al momento preferenze facoltative da gestire. Questa pagina sarà ampliata se in futuro
        verranno introdotti cookie di terze parti.
      </p>
    </div>
  </section>
</BaseLayout>
