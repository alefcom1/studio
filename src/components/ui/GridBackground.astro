---
interface Props {
  watermark?: boolean;
}
const { watermark = true } = Astro.props;
---
<div aria-hidden="true" class="grid-bg"></div>
<div aria-hidden="true" class="grid-bg__fade"></div>
{watermark && (
  <div aria-hidden="true" class="watermark" data-spin>
    <svg width="620" height="620" viewBox="0 0 32 32">
      <g stroke="#2440C8" stroke-width="2.6" fill="none">
        <path d="M16 2.5v27"></path>
        <path d="M27.69 9.25 4.31 22.75"></path>
        <path d="M4.31 9.25 27.69 22.75"></path>
      </g>
    </svg>
  </div>
)}

<style>
  .watermark {
    position: absolute;
    right: -150px;
    top: -130px;
    width: 620px;
    height: 620px;
    opacity: 0.055;
    pointer-events: none;
  }
</style>
