# ─────────────────────────────────────────────────────────────────────────────
# Remarka Lab · Monitor — PRODUCTION .env template
#
# Copy this to `.env` NEXT TO the code + override on the server:
#   cp .env.prod.template .env      (then fill every "СГЕНЕРИРОВАТЬ"/"ВСТАВИТЬ")
#
# ⚠️ NEVER commit the filled-in .env. This template holds ONLY placeholders.
# ⚠️ Do NOT wrap values in quotes — Compose passes them through literally.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Generate a strong password once, e.g.:  openssl rand -base64 24 | tr -d '/+='
POSTGRES_PASSWORD=СГЕНЕРИРОВАТЬ
# Must reuse the SAME password as above. Host is the compose service name `db`.
DATABASE_URL=postgresql://sitelens:СГЕНЕРИРОВАТЬ@db:5432/sitelens

# ── Redis ────────────────────────────────────────────────────────────────────
# Internal service name; no auth needed (not published, internal network only).
REDIS_URL=redis://redis:6379

# ── App runtime ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Public origin. Everything runs behind Caddy on this one host/origin.
API_BASE_URL=https://lab.remarka.biz
FRONTEND_URL=https://lab.remarka.biz

# Baked into the web bundle at BUILD time (see setup.md step 4). Keep it equal to
# the public origin so the browser calls its own origin for /api and /ws.
NEXT_PUBLIC_API_URL=https://lab.remarka.biz

# Restrict which browser origins may call the API (belt + braces; same-origin
# means this is rarely exercised, but do NOT leave it empty in production).
CORS_ORIGIN=https://lab.remarka.biz

# ── AI recommendations (Claude / Anthropic) — Option B: DIRECT ───────────────
# Egress from the EU VPS to api.anthropic.com is open, so use the direct key and
# leave the Vercel proxy vars empty. Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=ВСТАВИТЬ-КЛЮЧ-ANTHROPIC
ANTHROPIC_MODEL=claude-sonnet-4-6
# Leave these EMPTY (proxy not used in this deployment):
ANTHROPIC_PROXY_URL=
ANTHROPIC_PROXY_SECRET=

# ── Google integrations (optional) ───────────────────────────────────────────
# Search Console OAuth. After filling client id/secret, you MUST also register
# the redirect URI below in Google Cloud Console → Credentials → your OAuth
# client → "Authorized redirect URIs".
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REDIRECT_URI=https://lab.remarka.biz/api/integrations/gsc/callback

# PageSpeed Insights key (free). Can reuse the same PSI key used on the WP site.
PSI_API_KEY=

# ── Yandex integrations (optional) ───────────────────────────────────────────
# One OAuth app covers Webmaster + Metrica + Wordstat. Register the redirect URI
# below in https://oauth.yandex.ru/client/ → your app → Redirect URI.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://lab.remarka.biz/api/integrations/yandex/callback

# OpenPageRank (free) — domain authority metric (optional).
OPEN_PAGE_RANK_API_KEY=

# ── Alerts (optional) ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
TELEGRAM_BOT_TOKEN=

# ── Cabinet (client portal, K1) ───────────────────────────────────────────────
# Public origin of the client portal (separate host from lab.remarka.biz).
CABINET_URL=https://cab.remarka.biz
# Brevo transactional email (owner decision 16.07.2026 — EU region, GDPR).
# Leave EMPTY to run in dev mode: the app logs the magic-link URL to stdout
# instead of sending it — it does NOT crash or fail startup without a key,
# but real clients cannot log in until a real key is set here. Get a key at
# https://app.brevo.com (API keys & tokens) after verifying the remarka.biz
# sending domain (SPF/DKIM/DMARC) in Brevo.
BREVO_API_KEY=
EMAIL_FROM=no-reply@remarka.biz
# Magic-link TTL and session length — match piano-cabinet-k1.md §4.
MAGIC_TTL_MINUTES=15
SESSION_TTL_DAYS=7
