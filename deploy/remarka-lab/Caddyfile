# ─────────────────────────────────────────────────────────────────────────────
# Remarka Lab · Monitor — Caddy v2 reverse proxy
#
#   Browser ──TLS/Basic Auth──▶ Caddy ─┬─ /api/*  /ws*  /health ─▶ api:3001
#                                       └─ everything else        ─▶ web:3000
#
# The whole site sits behind HTTP Basic Auth (the app itself has NO auth). Caddy
# gets a Let's Encrypt cert automatically for lab.remarka.biz (ports 80/443 must
# be open — they are: ufw allows 80/443).
#
# Routing rationale (verified against the code, read-only):
#   • API routes are registered with a literal `/api/...` prefix inside each
#     route file (e.g. `fastify.get('/api/projects', ...)`), NOT via a Fastify
#     prefix — so proxy /api/* verbatim (do NOT strip the prefix).
#   • WebSocket lives at `/ws/crawl/:id` (apps/api/src/ws/index.ts). The web
#     client (apps/web/src/lib/ws.ts) takes NEXT_PUBLIC_API_URL, swaps http→ws,
#     and connects to `<origin>/ws/crawl/...`. With NEXT_PUBLIC_API_URL baked as
#     https://lab.remarka.biz that becomes wss://lab.remarka.biz/ws/... — Caddy
#     upgrades it transparently via the same reverse_proxy.
#   • Health check is `/health` (no /api prefix) — routed to api so the owner can
#     `curl -u user:pass https://lab.remarka.biz/health`.
#   • The web client's BASE (apps/web/src/lib/api.ts) is NEXT_PUBLIC_API_URL, so
#     with it baked to the public origin the browser calls the SAME origin →
#     no CORS preflight needed (CORS_ORIGIN is still pinned server-side as belt +
#     braces).
# ─────────────────────────────────────────────────────────────────────────────

{
	# Contact address for Let's Encrypt expiry notices. Replace if desired.
	email admin@remarka.biz
}

lab.remarka.biz {
	encode zstd gzip

	# ── No Basic Auth anymore (M2 cutover, unica-utenza) ──────────────────────
	# Lab is now app-guarded, not gated at the edge: every protected page runs
	# requireLabSession() (redirects to the cabinet login on cab.remarka.biz) and
	# every data route is behind the API auth + tenant guard (server.ts). Access
	# is by the shared `cab_session` cookie (Domain=.remarka.biz — set COOKIE_DOMAIN
	# on the cabinet service). The public vetrina (/showcase, /api/public/*) is
	# open by design. Removing Basic Auth is the go-live moment for open access;
	# PREREQUISITES (see setup.md → "M2 cutover"): prisma db push applied,
	# cabinet redeployed with COOKIE_DOMAIN=.remarka.biz, web rebuilt with
	# NEXT_PUBLIC_CABINET_URL. Without those a logged-in user bounces in a redirect
	# loop. To roll back, re-add a `basic_auth { ... }` block here and reload Caddy.

	# ── WebSocket: /ws and everything under it → api ─────────────────────────
	@ws path /ws /ws/*
	handle @ws {
		reverse_proxy api:3001
	}

	# ── REST API: /api/* → api (prefix preserved) ────────────────────────────
	handle /api/* {
		reverse_proxy api:3001
	}

	# ── Health probe: /health → api ──────────────────────────────────────────
	handle /health {
		reverse_proxy api:3001
	}

	# ── Everything else → Next.js web ────────────────────────────────────────
	handle {
		reverse_proxy web:3000
	}

	# Access + error logs to stdout (view with: docker compose ... logs caddy).
	log {
		output stdout
		format console
	}
}

# ─────────────────────────────────────────────────────────────────────────────
# Cabinet (client portal, K1) — cab.remarka.biz
#
#   Browser ──TLS, NO Basic Auth──▶ Caddy ─▶ cabinet:3002 (everything)
#
# Deliberately separate from lab.remarka.biz above: this is the PUBLIC client
# login, so it must NOT sit behind Basic Auth (a real client has no way to
# get that username/password). The app does its own auth end-to-end
# (magic-link + server-side session cookie) — see piano-cabinet-k1.md §4-5.
# Monitor's api/web are NOT reachable from this site block at all; isolation
# between "internal tool" and "public client portal" is at the Caddy-host
# level, not by selectively filtering paths.
#
# Precondition: DNS A-record cab.remarka.biz → 178.105.192.76 must exist
# BEFORE first start, or the ACME HTTP-01 challenge for the TLS cert fails.
# ─────────────────────────────────────────────────────────────────────────────

cab.remarka.biz {
	# NO basic_auth block here — see rationale above.
	encode zstd gzip
	reverse_proxy cabinet:3002

	log {
		output stdout
		format console
	}
}

# ─────────────────────────────────────────────────────────────────────────────
# WordPress remarka.biz — БОЕВОЙ (cutover выполнен 17.07.2026,
# docs/migrazione-wp-hetzner.md). Стейджинг-блок new.remarka.biz удалён:
# миграция шла сразу на боевой домен, A-записи new.* не существует, и блок
# лишь заставлял Caddy бесконечно ретраить ACME-челлендж.
# ─────────────────────────────────────────────────────────────────────────────

remarka.biz {
	# Prestazioni (17.07.2026, регрессия после миграции): сжатие + кэш статики.
	# Старый хостинг делал gzip/expires на nginx — Caddy по умолчанию НЕ сжимает.
	encode zstd gzip

	# CSS/JS/шрифты версионируются через ?ver=filemtime (remarka_enqueue_assets
	# в functions.php) — при правке файла URL меняется сам, поэтому можно
	# кэшировать агрессивно и без ревалидации (immutable), 1 год (LCP-раунд 2,
	# 18.07.2026).
	@static-versioned path *.css *.js *.woff2
	header @static-versioned Cache-Control "public, max-age=31536000, immutable"

	# Картинки версий в URL не несут — оставляем прежние 30 дней.
	@static-images path *.svg *.png *.jpg *.jpeg *.webp *.ico
	header @static-images Cache-Control "public, max-age=2592000"

	reverse_proxy wordpress:80

	log {
		output stdout
		format console
	}
}

www.remarka.biz {
	redir https://remarka.biz{uri} permanent
}
